---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  book: CollectionEntry<'books'>;
}

const { book } = Astro.props;
const { title, author, coverImage } = book.data;
---

<a href={`/kitaplar/${book.slug}/`} class="book-card">
  <div class="cover-wrapper">
    {coverImage ? (
      <Image src={coverImage} alt={`${title} Kapak Resmi`} format="webp" width={300} aspectRatio={"2/3"} quality="mid" loading="lazy" decoding="async" />
    ) : (
      <div class="cover-placeholder">Görsel Yok</div>
    )}
  </div>
  <div class="book-meta">
    <h3 class="title">{title}</h3>
    <p class="author">{author}</p>
  </div>
</a>

<style>
  .book-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background-color: var(--color-bg);
    border: 1px solid var(--color-bg-secondary);
    border-radius: 2px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .book-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.08); border-color: #d0d0d0;
  }
  .book-card:hover .title {
      color: var(--color-accent);
  }

  .cover-wrapper {
    aspect-ratio: 2 / 3;
    overflow: hidden;
    background-color: var(--color-bg-secondary);
  }

  .cover-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  
  .book-card:hover .cover-wrapper img {
      transform: scale(1.02);
  }

  .cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-style: italic;
  }

  .book-meta {
    padding: 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .title {
    font-size: 1.2rem;
    margin-bottom: 0.25rem;
    line-height: 1.3;
    font-weight: 700;
    transition: color 0.15s ease;
  }

  .author {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-top: auto;
  }
</style>
