---
import '../styles/global.css';
import { Image } from 'astro:assets';
import logoImage from '../assets/images/Logo-ters.png';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "z-eksen e-yayıncılık. İnsanın kadim ve çağdaş meselelerine derinlikli yaklaşımlar" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description || "Z-Eksen e-yayıncılık. İnsanın kadim ve çağdaş meselelerine derinlikli yaklaşımlar."} />
    
    <!-- SEO & Canonical -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Font Preload -->
    <link rel="preload" href="/fonts/cormorant-garamond-regular.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/cormorant-garamond-bold.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/cormorant-garamond-italic.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="tr_TR" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-logo-container">
          <Image src={logoImage} format="webp" width={80} loading="eager" alt="Z-Eksen Yayıncılık Logo" class="header-logo" /> 
          <span class="site-title-lowercase">z-eksen e-yayıncılık</span>
        </a>
        
        <div class="header-social">
          <a href="https://x.com/eksen3017" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/zeksen.eyayincilik/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/z-eksen-e-yay%C4%B1nc%C4%B1l%C4%B1k/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>

        <nav>
          <a href="/kitaplar/">Kitaplar</a>
          <a href="/diziler/">Diziler</a>
          <a href="/manifesto/">Manifesto</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>z-eksen e-yayıncılık &copy; {new Date().getFullYear()}. İnsanın kadim ve çağdaş meselelerine derinlikli yaklaşımlar.</p>
        <div class="footer-contact" style="margin-bottom: 0.5rem;">İletişim: <a href="mailto:info@z-eksen.org">info@z-eksen.org</a></div>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    background-color: var(--color-text);
    color: var(--color-bg);
    padding: 1.5rem 0;
  }
  .site-header .container {
    padding: 0 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .site-header a {
    color: var(--color-bg);
    text-decoration: none;
  }
  .site-header a:hover {
    color: var(--color-accent);
  }
  .site-logo-container {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--color-text);
  }
  .header-logo {
    height: 40px;
    width: auto;
  }
  .site-title-lowercase {
    font-size: 1.5rem;
    letter-spacing: 1px;
    font-weight: 700;
  }
  nav {
    display: flex;
    gap: 1.5rem;
    font-weight: 700;
  }
  .header-social {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    margin: 0 auto 0 2rem; /* site ismi ile menü arasına yerleşmesi için */
  }
  .header-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    opacity: 0.9;
  }
  .header-social a:hover {
    opacity: 1;
    transform: translateY(-2px);
  }
  .header-social svg {
    width: 22px;
    height: 22px;
    fill: var(--color-bg);
    transition: fill 0.2s ease;
  }
  .header-social a:hover svg {
    fill: var(--color-accent);
  }
  .site-footer {
    border-top: 1px solid var(--color-bg-secondary);
    margin-top: 4rem;
    padding: 2rem 0;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
  @media (max-width: 600px) {
    .site-header .container {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
    nav {
      justify-content: center;
      width: 100%;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .header-social {
      margin: 0.5rem auto 0 auto;
      justify-content: center;
      width: 100%;
    }
  }
</style>
