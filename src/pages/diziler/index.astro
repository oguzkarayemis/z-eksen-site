---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const diziler = await getCollection('diziler');
---

<Layout title="Diziler | z-eksen e-yayıncılık" description="z-eksen e-yayıncılık tarafından sunulan tüm içerik dizileri.">
  <section class="hero">
    <h1>Diziler</h1>
    <p class="subtitle">Kürasyonu özenle yapılmış tematik koleksiyonlarımız.</p>
  </section>

  <section class="diziler-list">
    <div class="dizi-grid">
      {diziler.map((dizi) => (
        <a href={`/diziler/${dizi.slug}/`} class="dizi-card">
          <h2 class="dizi-title">{dizi.data.title}</h2>
          <p class="dizi-desc">{dizi.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .hero {
    margin: 4rem 0 2rem;
    text-align: center;
  }
  .hero h1 {
    font-size: 2.5rem;
    color: var(--color-text);
  }
  .subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    font-style: italic;
  }
  .dizi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    padding: 1rem 0;
  }
  .dizi-card {
    display: block;
    padding: 2rem;
    background-color: var(--color-bg);
    border: 1px solid var(--color-bg-secondary);
    border-radius: 2px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .dizi-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.08);
    border-color: #d0d0d0;
  }
  .dizi-title {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-text);
    transition: color 0.15s ease;
  }
  .dizi-card:hover .dizi-title {
    color: var(--color-accent);
  }
  .dizi-desc {
    color: var(--color-text-muted);
    line-height: 1.6;
  }
</style>
